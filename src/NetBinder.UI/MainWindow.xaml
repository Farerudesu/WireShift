<Window x:Class="NetBinder.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NetBinder.UI.ViewModels"
        xmlns:local="clr-namespace:NetBinder.UI"
        xmlns:conv="clr-namespace:NetBinder.UI.Converters"
        mc:Ignorable="d"
        Title="NetBinder - Network Interface Binding Manager" Height="820" Width="1180"
        MinHeight="700" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Converters -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <conv:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <conv:BindingCountConverter x:Key="BindingCountConverter"/>
        <conv:BindingCountToVisibilityConverter x:Key="BindingCountToVisConverter"/>

        <!-- Color Palette (Standard Windows Light Theme) -->
        <SolidColorBrush x:Key="WindowBg" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="SurfaceBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBg" Color="#FAFAFA"/>
        <SolidColorBrush x:Key="BorderBrushDefault" Color="#D1D1D1"/>
        <SolidColorBrush x:Key="BorderBrushActive" Color="#9E9E9E"/>
        <SolidColorBrush x:Key="TextDark" Color="#202020"/>
        <SolidColorBrush x:Key="TextMuted" Color="#5F6368"/>

        <SolidColorBrush x:Key="WindowsAccent" Color="#0078D7"/>
        <SolidColorBrush x:Key="WindowsGreen" Color="#107C41"/>
        <SolidColorBrush x:Key="WindowsRed" Color="#E81123"/>
        <SolidColorBrush x:Key="WindowsYellow" Color="#FFB900"/>
        <SolidColorBrush x:Key="WindowsOrange" Color="#D83B01"/>
        <SolidColorBrush x:Key="HelpBg" Color="#EAF2FA"/>
        <SolidColorBrush x:Key="HelpBorder" Color="#B3D1EE"/>

        <!-- Base style for ListBoxes -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Base style for Buttons -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for section headers -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource WindowsAccent}"/>
            <Setter Property="Margin" Value="8,8,8,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar / status -->
            <RowDefinition Height="Auto"/>   <!-- Instruction Banner -->
            <RowDefinition Height="*"/>       <!-- Main content -->
            <RowDefinition Height="Auto"/>   <!-- Bindings list -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Row 0: Header + Status indicators -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="NetBinder" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource WindowsAccent}" Margin="8,0"/>
                <TextBlock Text="v1.0" FontSize="12" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Bottom" Margin="0,0,0,4"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Status Badge -->
                <Border CornerRadius="4" Padding="8,4" Background="{StaticResource CardBg}" BorderThickness="1" BorderBrush="{StaticResource BorderBrushDefault}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                 Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusBadgeText" Text="CONNECTED" Foreground="{StaticResource WindowsGreen}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                            <Setter Property="Text" Value="DISCONNECTED"/>
                                            <Setter Property="Foreground" Value="{StaticResource WindowsRed}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Button Content="Refresh All" Command="{Binding RefreshAllCommand}" Margin="8,0,0,0" Padding="14,6"/>
            </StackPanel>
        </Grid>

        <!-- Row 1: Instruction Banner -->
        <Border Grid.Row="1" Background="{StaticResource HelpBg}" BorderBrush="{StaticResource HelpBorder}"
                BorderThickness="1" CornerRadius="6" Padding="12" Margin="4,0,4,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="💡" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Quick Instructions on How to Use NetBinder:" FontWeight="Bold" Foreground="{StaticResource WindowsAccent}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource TextDark}" TextWrapping="Wrap">
                        <Run Text="1. Connection:" FontWeight="Bold"/> NetBinder will automatically attempt to connect to the background service.
                        <LineBreak/>
                        <Run Text="2. Binding:" FontWeight="Bold"/> Select a <Run Text="Network Interface" FontWeight="Bold"/>, and choose a <Run Text="Network Process" FontWeight="Bold"/>, then click <Run Text="Bind" FontWeight="Bold"/>. <Run Text="Tip:" FontWeight="Bold" Foreground="{StaticResource WindowsAccent}"/> Double-click a process to bind it instantly!
                        <LineBreak/>
                        <Run Text="3. Interface Metric:" FontWeight="Bold"/> Select an interface to edit its metric directly inline and press <Run Text="Enter" FontWeight="Bold"/> to save.
                        <LineBreak/>
                        <Run Text="4. Routing Traffic:" FontWeight="Bold" Foreground="{StaticResource WindowsOrange}"/> To route traffic, copy the SOCKS5 proxy endpoint from the table below and configure it in your application's proxy settings.
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2: Main content - Two panels side by side -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>  <!-- Bind button column -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Loading overlay indicator -->
            <ProgressBar Grid.ColumnSpan="3" Height="3" IsIndeterminate="True" 
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}}"
                         VerticalAlignment="Top" BorderThickness="0" Background="Transparent" Foreground="{StaticResource WindowsAccent}"
                         Panel.ZIndex="100"/>

            <!-- Left Panel: Network Interfaces -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock Text="Network Interfaces" Style="{StaticResource SectionHeader}" DockPanel.Dock="Left"/>
                    <Button Content="Refresh Adapters" Command="{Binding RefreshAdaptersCommand}"
                            DockPanel.Dock="Right" Padding="8,2" FontSize="10"/>
                </DockPanel>

                <ListBox Grid.Row="1" ItemsSource="{Binding Adapters}"
                          SelectedItem="{Binding SelectedAdapter}"
                          SelectedIndex="{Binding SelectedAdapterIndex}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderBrushDefault}" BorderThickness="1"
                                    CornerRadius="4" Padding="8" Margin="2"
                                    Background="{StaticResource CardBg}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding FriendlyName}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource WindowsGreen}" FontSize="13"/>
                                        
                                        <!-- Mappings Count Badge -->
                                        <Border Background="{StaticResource WindowsAccent}" CornerRadius="3"
                                                Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                            <Border.Visibility>
                                                <MultiBinding Converter="{StaticResource BindingCountToVisConverter}">
                                                    <Binding Path="InterfaceIndex"/>
                                                    <Binding Path="DataContext.Bindings" RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                                                </MultiBinding>
                                            </Border.Visibility>
                                            <TextBlock FontSize="9" Foreground="White" FontWeight="SemiBold">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource BindingCountConverter}">
                                                        <Binding Path="InterfaceIndex"/>
                                                        <Binding Path="DataContext.Bindings" RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>

                                        <TextBlock Text=" (" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding InterfaceType}" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                        <TextBlock Text=")" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Foreground="{StaticResource TextDark}" Margin="0,2,0,0">
                                        <Run Text="IP: "/><Run Text="{Binding IpAddress, Mode=OneWay}" FontWeight="SemiBold"/>
                                    </TextBlock>

                                    <!-- Inline Metric Editing Grid -->
                                    <Grid Margin="0,4,0,0">
                                        <!-- Normal display state -->
                                        <StackPanel x:Name="NormalMetricPanel" Orientation="Horizontal">
                                            <TextBlock Text="Metric: " Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                            <TextBlock Text="{Binding InterfaceMetric}" Foreground="{StaticResource WindowsOrange}" FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Text=" | MAC: " Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                            <TextBlock Text="{Binding MacAddress}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                        </StackPanel>

                                        <!-- Editing display state (visible when row is selected) -->
                                        <StackPanel x:Name="EditMetricPanel" Orientation="Horizontal" Visibility="Collapsed">
                                            <TextBlock Text="Metric: " Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBox x:Name="MetricEditBox" Width="50" FontSize="11" Margin="2,0" VerticalAlignment="Center" Padding="4,1"
                                                     Text="{Binding DataContext.MetricInput, RelativeSource={RelativeSource AncestorType=ListBox}, UpdateSourceTrigger=PropertyChanged}"
                                                     KeyDown="MetricTextBox_KeyDown" LostFocus="MetricTextBox_LostFocus">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDefault}"/>
                                                        <Setter Property="Background" Value="White"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.IsMetricInputValid, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="False">
                                                                <Setter Property="BorderBrush" Value="{StaticResource WindowsRed}"/>
                                                                <Setter Property="ToolTip" Value="Metric must be a number between 1 and 9999"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <Button Content="Reset" Command="{Binding DataContext.ResetMetricCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    FontSize="9" Padding="4,1" Height="18" Margin="4,0" VerticalAlignment="Center"
                                                    Style="{StaticResource {x:Type Button}}"
                                                    ToolTip="Reset metric to default"/>
                                            <TextBlock Text=" | MAC: " Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding MacAddress}" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="NormalMetricPanel" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="EditMetricPanel" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Selected adapter details -->
                <Border Grid.Row="2" Background="{StaticResource SurfaceBg}" CornerRadius="4"
                        Padding="8" Margin="4" MinHeight="60"
                        BorderBrush="{StaticResource BorderBrushDefault}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Adapter Details" Foreground="{StaticResource WindowsAccent}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway: " Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAdapter.Gateway}" Foreground="{StaticResource TextDark}" FontSize="11"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="DNS Server: " Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedAdapter.DnsServer}" Foreground="{StaticResource TextDark}" FontSize="11"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Subnet Mask: " Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedAdapter.SubnetMask}" Foreground="{StaticResource TextDark}" FontSize="11"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Interface Index: " Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedAdapter.InterfaceIndex}" Foreground="{StaticResource TextDark}" FontSize="11"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Center: Bind Button (Arrow) + Routing Method Selector -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12">
                <Button Content="Bind --&gt;" Command="{Binding BindCommand}"
                        Background="{StaticResource WindowsAccent}" Foreground="White"
                        FontWeight="Bold" Padding="18,14" FontSize="14" BorderThickness="0"
                        ToolTip="Bind Selected Process to Selected Network Interface">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#005A9E"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Routing Method Card -->
                <Border BorderBrush="{StaticResource BorderBrushDefault}" BorderThickness="1" 
                        CornerRadius="4" Padding="10,8" Margin="4,12,4,4" Background="{StaticResource CardBg}">
                    <StackPanel>
                        <TextBlock Text="Routing Method" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6" Foreground="{StaticResource WindowsAccent}"/>
                        <RadioButton Content="Transparent" 
                                     IsChecked="{Binding IsDefaultRoutingTransparent, Mode=TwoWay}" 
                                     FontSize="11" Margin="0,2"
                                     ToolTip="Intercepts and routes traffic automatically (requires admin elevation)."/>
                        <RadioButton Content="Manual Proxy" 
                                     IsChecked="{Binding IsDefaultRoutingProxyOnly, Mode=TwoWay}" 
                                     FontSize="11" Margin="0,2"
                                     ToolTip="Configures SOCKS5 proxy per interface. You must set proxy settings inside the app manually."/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right Panel: Running Processes with Network Connections -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Title -->
                    <RowDefinition Height="Auto"/> <!-- Search bar -->
                    <RowDefinition Height="*"/>    <!-- Process List -->
                    <RowDefinition Height="Auto"/> <!-- Details -->
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock Text="Network Processes" Style="{StaticResource SectionHeader}" DockPanel.Dock="Left"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <TextBlock Text="Updated: " Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ProcessesLastUpdated}" Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="Refresh" Command="{Binding RefreshProcessesCommand}" Padding="8,2" FontSize="10"/>
                    </StackPanel>
                </DockPanel>

                <!-- Search/Filter Input Box -->
                <Grid Grid.Row="1" Margin="4,2,4,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ProcessSearchFilter, UpdateSourceTrigger=PropertyChanged}"
                             Background="White" Foreground="{StaticResource TextDark}"
                             BorderBrush="{StaticResource BorderBrushDefault}" Padding="22,4,6,4"
                             FontSize="11" Margin="0" x:Name="SearchBox"
                             ToolTip="Type to filter processes by name, PID, or path"/>
                    <TextBlock Grid.Column="0" Text="🔍" Foreground="{StaticResource TextMuted}" 
                               FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="6,0,0,0" IsHitTestVisible="False"/>
                    <Button Grid.Column="1" Content="Clear" Command="{Binding ClearSearchCommand}" Padding="8,2" FontSize="10" Margin="4,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProcessSearchFilter}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <ListBox Grid.Row="2" ItemsSource="{Binding Processes}"
                          SelectedItem="{Binding SelectedProcess}"
                          SelectedIndex="{Binding SelectedProcessIndex}"
                          MouseDoubleClick="ProcessList_MouseDoubleClick"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderBrushDefault}" BorderThickness="1"
                                    CornerRadius="4" Padding="8" Margin="2"
                                    Background="{StaticResource CardBg}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ProcessName}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextDark}" FontSize="13"/>
                                            <!-- Binding indicator -->
                                            <Border Background="{StaticResource WindowsAccent}" CornerRadius="3"
                                                    Padding="4,1" Margin="6,0,0,0"
                                                    Visibility="{Binding IsBound, Converter={StaticResource BoolToVisConverter}}">
                                                <TextBlock Text="{Binding BoundInterfaceName}" FontSize="9"
                                                           Foreground="White" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding FilePath}" Foreground="{StaticResource TextMuted}"
                                                   FontSize="10" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="380"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Foreground="{StaticResource WindowsOrange}" FontSize="11" HorizontalAlignment="Right" FontWeight="SemiBold">
                                            <Run Text="PID: "/><Run Text="{Binding Pid, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10" HorizontalAlignment="Right">
                                            <Run Text="Conns: "/><Run Text="{Binding ActiveConnectionCount, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Process details -->
                <Border Grid.Row="3" Background="{StaticResource SurfaceBg}" CornerRadius="4"
                        Padding="8" Margin="4" MinHeight="40"
                        BorderBrush="{StaticResource BorderBrushDefault}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Process Connections" Foreground="{StaticResource WindowsAccent}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <ItemsControl ItemsSource="{Binding SelectedProcess.Connections}" MaxHeight="100">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="100">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="{StaticResource TextMuted}" FontSize="10">
                                        <Run Text="{Binding LocalEndPoint, Mode=OneWay}"/>
                                        <Run Text=" -> "/>
                                        <Run Text="{Binding RemoteEndPoint, Mode=OneWay}"/>
                                        <Run Text=" [" Foreground="{StaticResource BorderBrushActive}"/>
                                        <Run Text="{Binding State, Mode=OneWay}" Foreground="{StaticResource WindowsGreen}"/>
                                        <Run Text="]" Foreground="{StaticResource BorderBrushActive}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Row 3: Tab Control for Bindings + Load Balancing -->
        <TabControl Grid.Row="3" Margin="0,8,0,0" Background="{StaticResource SurfaceBg}"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    BorderBrush="{StaticResource BorderBrushDefault}" BorderThickness="1">

            <!-- Tab 1: Active Bindings -->
            <TabItem Header="Binding Mappings" FontSize="12" Padding="12,4">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ListBox Grid.Column="0" ItemsSource="{Binding Bindings}"
                               SelectedItem="{Binding SelectedBinding}"
                               SelectedIndex="{Binding SelectedBindingIndex}"
                               MinHeight="100" MaxHeight="220">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource WindowsGreen}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Fill" Value="{StaticResource WindowsRed}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Foreground="{StaticResource TextDark}" FontSize="12">
                                            <Run Text="{Binding ProcessName, Mode=OneWay}" FontWeight="Bold"/>
                                            <Run Text="  →  " Foreground="{StaticResource TextMuted}"/>
                                            <Run Text="{Binding InterfaceName, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource WindowsGreen}"/>
                                            <Run Text="  [" Foreground="{StaticResource TextMuted}"/>
                                            <Run Text="{Binding Mode, Mode=OneWay}" Foreground="{StaticResource WindowsAccent}" FontSize="10"/>
                                            <Run Text="]" Foreground="{StaticResource TextMuted}"/>
                                        </TextBlock>
                                        <!-- Route Mode Row -->
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="Route Mode: " Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center"/>
                                            <TextBlock FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Transparent Redirect"/>
                                                        <Setter Property="Foreground" Value="{StaticResource WindowsGreen}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RoutingMethod}" Value="ProxyOnly">
                                                                <Setter Property="Foreground" Value="{StaticResource WindowsOrange}"/>
                                                                <Setter Property="Text" Value="Manual Proxy (SOCKS5)"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button Content="Switch Mode" 
                                                    Command="{Binding DataContext.ToggleRoutingMethodCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="6,0" Height="16" FontSize="8" Margin="8,0,0,0" VerticalAlignment="Center" 
                                                    Style="{StaticResource {x:Type Button}}"
                                                    ToolTip="Switch between Transparent redirection and Manual Proxy mode"/>
                                        </StackPanel>

                                        <!-- Proxy Endpoint Row -->
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="Proxy Endpoint: " Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ProxyAddress, Mode=OneWay}" Foreground="{StaticResource WindowsOrange}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Button Content="Copy" Click="CopyProxy_Click" Tag="{Binding ProxyAddress}" Padding="4,0" Height="16" FontSize="8" Margin="6,0,0,0" VerticalAlignment="Center" 
                                                    Style="{StaticResource {x:Type Button}}"
                                                    ToolTip="Copy Proxy Address to Clipboard"/>
                                            <TextBlock Text="  (Optional fallback)" Foreground="{StaticResource TextMuted}" FontSize="9" VerticalAlignment="Center" Margin="6,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RoutingMethod}" Value="ProxyOnly">
                                                                <Setter Property="Text" Value="  (Required - configure in application proxy settings)"/>
                                                                <Setter Property="Foreground" Value="{StaticResource WindowsOrange}"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Status Badge -->
                                    <Border Grid.Column="2" CornerRadius="3" Padding="6,2" Margin="12,0" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource WindowsGreen}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Background" Value="{StaticResource WindowsRed}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="White">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="ACTIVE"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Text" Value="INACTIVE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Inline Direct Delete Button -->
                                    <Button Grid.Column="3" Content="❌" 
                                             Command="{Binding DataContext.RemoveSpecificBindingCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                             CommandParameter="{Binding}"
                                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource WindowsRed}"
                                             FontSize="10" Padding="6,4" Margin="4,0" VerticalAlignment="Center"
                                             Style="{StaticResource {x:Type Button}}"
                                             ToolTip="Remove this binding rule"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,0">
                        <Button Content="Toggle Active" Command="{Binding ToggleBindingCommand}" Width="110"/>
                        <Button Content="Remove Rule" Command="{Binding RemoveBindingCommand}" Width="110"
                                Background="{StaticResource WindowsRed}" Foreground="White"
                                ToolTip="Remove selected binding rule">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#B2101E"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 2: Load Balancing (disabled/placeholder) -->
            <TabItem Header="Load Balancing" IsEnabled="False" Foreground="{StaticResource BorderBrushActive}">
                <Grid Background="#FAFAFA" Margin="16">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Load Balancing Control" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Coming in a future update (Phase 5)" FontSize="13"
                                   Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="11" TextAlignment="Center" MaxWidth="550" TextWrapping="Wrap"
                                   Text="Load balancing distributes network connections across multiple interfaces based on configurable weights. This requires the WFP kernel callout driver (Phase 6) for transparent operation, or can work with SOCKS5 proxy support for apps that support proxy configuration."/>
                        <Border Background="{StaticResource HelpBg}" CornerRadius="8" Padding="16" Margin="0,24,0,0"
                                BorderBrush="{StaticResource HelpBorder}" BorderThickness="1" Opacity="0.7">
                            <StackPanel>
                                <TextBlock Text="Planned Features:" Foreground="{StaticResource WindowsAccent}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Text="  - Weighted round-robin connection distribution" Foreground="{StaticResource TextDark}" FontSize="11" Margin="0,2"/>
                                <TextBlock Text="  - Per-destination session affinity (LRU cache)" Foreground="{StaticResource TextDark}" FontSize="11" Margin="0,2"/>
                                <TextBlock Text="  - Interface health monitoring with automatic failover" Foreground="{StaticResource TextDark}" FontSize="11" Margin="0,2"/>
                                <TextBlock Text="  - Real-time throughput statistics per interface" Foreground="{StaticResource TextDark}" FontSize="11" Margin="0,2"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Row 4: Status Bar -->
        <Border Grid.Row="4" Background="#E1E1E1" CornerRadius="4"
                Padding="8,4" Margin="0,6,0,0" BorderBrush="{StaticResource BorderBrushDefault}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="NetBinder Manager" Foreground="{StaticResource TextMuted}"
                           FontSize="10" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{StaticResource TextMuted}"
                           FontSize="10" HorizontalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Bindings: " Foreground="{StaticResource TextMuted}" FontSize="10"/>
                    <TextBlock Text="{Binding Bindings.Count}" Foreground="{StaticResource WindowsAccent}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Text=" | Adapters: " Foreground="{StaticResource TextMuted}" FontSize="10"/>
                    <TextBlock Text="{Binding Adapters.Count}" Foreground="{StaticResource WindowsAccent}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Text=" | Processes: " Foreground="{StaticResource TextMuted}" FontSize="10"/>
                    <TextBlock Text="{Binding Processes.Count}" Foreground="{StaticResource WindowsAccent}" FontSize="10" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Floating Non-Blocking Toast Banner Overlay (RowSpan covers all rows) -->
        <Border Grid.RowSpan="5" HorizontalAlignment="Center" VerticalAlignment="Top" 
                Margin="0,50,0,0" Padding="16,10" CornerRadius="6"
                Background="#323232" BorderBrush="#404040" BorderThickness="1"
                Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVisConverter}}"
                Panel.ZIndex="9999" MaxWidth="450">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding ToastMessage}" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Service Disconnected Screen Overlay (RowSpan covers all rows) -->
        <Grid Grid.RowSpan="5" Background="#F0F3F3F3" Panel.ZIndex="9000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border CornerRadius="8" Background="{StaticResource SurfaceBg}" 
                    BorderBrush="{StaticResource BorderBrushDefault}" BorderThickness="1"
                    Padding="32" Width="480" Height="250" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⚠️ NetBinder Service Disconnected" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource WindowsRed}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Could not establish communication with the background service. Please ensure the NetBinder Service is running with Administrator privileges." 
                               FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" TextAlignment="Center" Margin="0,0,0,24"/>
                    <Button Content="Connect to Service" Command="{Binding ConnectCommand}" 
                            Background="{StaticResource WindowsAccent}" Foreground="White" FontWeight="Bold" 
                            Padding="16,8" FontSize="13" HorizontalAlignment="Center" BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
